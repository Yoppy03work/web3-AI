# Anthropic API key. If empty, the app degrades gracefully: each item shows
# the English excerpt as its "summary" and the "why it matters" line is blank.
ANTHROPIC_API_KEY=

# Claude model used for batched Japanese summarization.
LLM_MODEL=claude-haiku-4-5

# How many of the freshest, tagged items to summarize per refresh.
DIGEST_MAX_ITEMS=12

# Cache TTL in minutes for the assembled digest (in-memory).
DIGEST_TTL_MINUTES=360

# Optional: when set, /api/digest?refresh=1 also requires &token=<value>.
# Use a long random string. Vercel Cron does NOT need this — it can hit
# the unguarded endpoint, or you can pass the token in the cron URL.
REFRESH_TOKEN=
