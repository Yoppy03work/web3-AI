# Anthropic API key. Required for Japanese summarization and full-body
# translation. If empty, the app degrades gracefully (shows English excerpts
# and skips body translation).
ANTHROPIC_API_KEY=

# Claude model used for summarization + translation.
# Use the dated snapshot ID to avoid 404s from alias resolution.
LLM_MODEL=claude-haiku-4-5-20251001

# How many of the freshest, tagged items to summarize per refresh.
DIGEST_MAX_ITEMS=12

# Cache TTL in minutes for the assembled digest (in-memory layer).
DIGEST_TTL_MINUTES=360

# Optional: when set, /api/digest?refresh=1 also requires &token=<value>.
# Use a long random string. Vercel Cron does not require this — it can hit
# the unguarded endpoint, or you can encode the token directly in vercel.json.
REFRESH_TOKEN=

# Turso (libSQL) — SQLite-compatible cloud database, accessed over its HTTP
# API (no SDK, zero runtime deps). Persists daily snapshots and per-article
# records (full body + Japanese translation) so the archive + detail pages
# survive serverless cold starts, and so you can query history with plain SQL.
#
# If both are empty, the app falls back to in-memory only (no durable history).
#
# Get these from https://app.turso.tech → your database → "Connect" /
# "Create Token". The URL may be shown as libsql://... — that's fine, the
# client rewrites it to https:// for the HTTP API.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
