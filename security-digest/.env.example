# Anthropic API key. Required for Japanese summarization and full-body
# translation. If empty, the app degrades gracefully (shows English excerpts
# and skips body translation).
ANTHROPIC_API_KEY=

# Claude model used for summarization + translation.
# Use the dated snapshot ID to avoid 404s from alias resolution.
LLM_MODEL=claude-haiku-4-5-20251001

# How many of the freshest, tagged items to summarize per refresh.
DIGEST_MAX_ITEMS=12

# Cache TTL in minutes for the assembled digest (in-memory layer).
DIGEST_TTL_MINUTES=360

# Refresh protection. A forced refresh (/api/digest?refresh=1) does a feed
# fan-out + a paid Anthropic call + a Slack post, so secure it in production.
#
# REFRESH_TOKEN: manual callers must pass &token=<value>.
# CRON_SECRET:   Vercel Cron auto-sends `Authorization: Bearer $CRON_SECRET`,
#                so setting it lets the morning cron authenticate without a
#                token in the URL. Recommended for production.
#
# Rule: if either is set, unauthenticated refreshes are rejected (401). If
# BOTH are empty, refresh stays open (fine for local/dev).
REFRESH_TOKEN=
CRON_SECRET=

# Optional NVD API key for CVE/CVSS enrichment. Without it, NVD allows ~5
# requests / 30s; with it, ~50 / 30s. Results are cached in SQL either way, so
# a key is only useful if many *new* CVEs appear per run.
# Get one free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Max number of *new* (uncached) CVEs to look up from NVD per refresh. Keeps
# the build within the rate limit; the rest fill in on later runs. Default 5.
NVD_MAX_LOOKUPS=5

# Slack Incoming Webhook. When set, every refresh (i.e. the morning cron)
# posts a digest summary to that channel. Unset = no notification.
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Public base URL used for links inside the Slack message. On Vercel this is
# auto-detected (VERCEL_PROJECT_PRODUCTION_URL); set explicitly to override.
SITE_URL=

# "重大のみ通知": CRITICAL | HIGH | MEDIUM | LOW. When set, Slack only posts when
# there are items whose CVE meets this bar, and lists just those. Unset =
# notify on every run with the top items.
SLACK_MIN_SEVERITY=

# Turso (libSQL) — SQLite-compatible cloud database, accessed over its HTTP
# API (no SDK, zero runtime deps). Persists daily snapshots and per-article
# records (full body + Japanese translation) so the archive + detail pages
# survive serverless cold starts, and so you can query history with plain SQL.
#
# If both are empty, the app falls back to in-memory only (no durable history).
#
# Get these from https://app.turso.tech → your database → "Connect" /
# "Create Token". The URL may be shown as libsql://... — that's fine, the
# client rewrites it to https:// for the HTTP API.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
